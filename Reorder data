class Solution(object):
    def reorderLogFiles(self, logs):
        res1 = []  # To store digit logs
        res2 = []  # To store letter logs
        for s in logs:
            parts = s.split(" ", 1)
            content = parts[1]
            if content.replace(" ", "").isdigit():
                res1.append(s)
            else:
                res2.append(s)
        def get_sort_key(log_string):
            parts = log_string.split(" ", 1)
            identifier = parts[0]
            content = parts[1]
            return (content, identifier)
        res2.sort(key=get_sort_key)
        return res2 + res1
