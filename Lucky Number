#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>
int main() {
    char car_no[100];
    int sum = 0, isValid = 1;

    printf("Enter the car no:");
    scanf("%s", car_no);

    if (strlen(car_no) != 4) {
        isValid = 0;
    } else {
        for (int i = 0; i < 4; i++) {
            if (!isdigit(car_no[i])) {
                isValid = 0;
                break;
            }
            sum += car_no[i] - '0';
        }
    }
    if (isValid && atoi(car_no) <= 0) {
        isValid = 0;
    }
    if (!isValid) {
        printf("%s is not a valid car number\n", car_no);
    } else {
        if (sum % 3 == 0 || sum % 5 == 0 || sum % 7 == 0) {
            printf("Lucky Number\n");
        } else {
            printf("Sorry its not my lucky number\n");
        }
    }

    return 0;
}
